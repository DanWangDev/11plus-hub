# ── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=3009
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────
# DATABASE_URL takes precedence if set
# DATABASE_URL=postgresql://hub:hub_dev_password@localhost:5432/hub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hub
DB_USER=hub
DB_PASSWORD=hub_dev_password

# ── Security ──────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3009

# ── Admin Seed ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@labf.app
ADMIN_DISPLAY_NAME=Admin

# ── Google OAuth ─────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Cloudflare Turnstile ─────────────────────────────
# Get from https://dash.cloudflare.com/turnstile
# TURNSTILE_SITE_KEY=your-site-key
# TURNSTILE_SECRET_KEY=your-secret-key

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=debug
