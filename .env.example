# ── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────
# DATABASE_URL takes precedence if set
# DATABASE_URL=postgresql://hub:hub_dev_password@localhost:5432/hub
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hub
DB_USER=hub
DB_PASSWORD=hub_dev_password

# ── Security ──────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=debug
