{
  "name": "11plus-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Platform Identity Provider for the 11+ learning suite — OIDC SSO, app registry, subscriptions, and cross-app intelligence",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w packages/backend run dev",
    "build": "npm -w packages/backend run build",
    "start": "npm -w packages/backend run start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm -w packages/backend run test",
    "test:coverage": "npm -w packages/backend run test:coverage",
    "typecheck": "npm -w packages/backend run typecheck",
    "db:migrate": "npm -w packages/backend run db:migrate",
    "db:seed": "npm -w packages/backend run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-n": "^17.18.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.5"
  }
}
