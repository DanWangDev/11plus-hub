# ── Database ──────────────────────────────────────────
DB_NAME=hub
DB_USER=hub
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Server ────────────────────────────────────────────
PORT=3009
OIDC_ISSUER=https://hub.labf.app
CORS_ORIGIN=https://hub.labf.app
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────
# Generate: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_RANDOM_STRING_AT_LEAST_32_CHARS

# Generate: openssl rand -base64 48
OIDC_COOKIE_KEYS=CHANGE_ME_RANDOM_STRING_AT_LEAST_32_CHARS

# Generate an RSA JWK signing key (run once, save the output):
#   node -e "import('jose').then(async({generateKeyPair,exportJWK})=>{const{privateKey}=await generateKeyPair('RS256',{extractable:true});const jwk=await exportJWK(privateKey);jwk.kid='prod-key-1';jwk.use='sig';jwk.alg='RS256';console.log(JSON.stringify(jwk))})"
# Paste the full JSON string here (single line):
OIDC_SIGNING_KEY=

# ── Admin Seed ───────────────────────────────────────
ADMIN_USERNAME=BigDaddy
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=admin@labf.app
ADMIN_DISPLAY_NAME=Big Daddy

# ── Google OAuth ─────────────────────────────────────
# From https://console.cloud.google.com/apis/credentials
# Add https://hub.labf.app to authorized origins and redirect URIs
GOOGLE_CLIENT_ID=

# ── Cloudflare Turnstile ─────────────────────────────
# From https://dash.cloudflare.com/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Cloudflare Tunnel ────────────────────────────────
# From: cloudflared tunnel create hub
TUNNEL_TOKEN=

# ── Migration (one-time) ─────────────────────────────
# Directory containing vocab-master.db and writing-buddy.db
# Used by: docker compose -f docker-compose.prod.yml --profile migration run --rm migrate-users
MIGRATION_DATA_DIR=./data
